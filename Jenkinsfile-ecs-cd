pipeline {
  agent any

  environment {
    ECR_REGISTRY = "760302898980.dkr.ecr.ap-south-1.amazonaws.com"
    AWS_REGION   = "ap-south-1"
    CLUSTER_NAME = "micro-dash-dev-cluster"
    PROJECT      = "micro-dash"
    ENVIRONMENT  = "dev"
  }

  options {
    disableConcurrentBuilds()
    buildDiscarder(logRotator(numToKeepStr: '10'))
    timeout(time: 30, unit: 'MINUTES')
    timestamps()
  }

  parameters {
    string(
      name: 'IMAGE_TAG',
      defaultValue: '',
      description: 'Image tag to deploy (e.g. v8.0.6)'
    )
    booleanParam(
      name: 'INIT_DB',
      defaultValue: false,
      description: 'Run DB initialization? First deploy only!'
    )
  }

  stages {

    stage('Validate') {
      steps {
        script {
          if (!params.IMAGE_TAG) {
            error "IMAGE_TAG parameter is required!"
          }
          env.DEPLOY_TAG = params.IMAGE_TAG
          echo "Deploying tag: ${env.DEPLOY_TAG}"
        }
      }
    }

    stage('Verify Image Signatures!') {
      steps {
        withCredentials([[
          $class: 'AmazonWebServicesCredentialsBinding',
          credentialsId: 'aws-ecr-credentials'
        ]]) {
          script {
            sh "aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${ECR_REGISTRY}"

            def services = ['frontend', 'gateway', 'user-service', 'order-service']
            services.each { service ->
              echo "Verifying signature for: ${service}:${env.DEPLOY_TAG}"
              sh """
                set -e
                docker pull ${ECR_REGISTRY}/${service}:${env.DEPLOY_TAG}
                IMAGE_DIGEST=\$(docker inspect --format='{{index .RepoDigests 0}}' ${ECR_REGISTRY}/${service}:${env.DEPLOY_TAG} | cut -d'@' -f2)
                echo "Verifying digest: \$IMAGE_DIGEST"
                cosign verify --key ${WORKSPACE}/cosign.pub --allow-insecure-registry ${ECR_REGISTRY}/${service}@\${IMAGE_DIGEST}
                echo "✅ ${service} signature VERIFIED!"
              """
            }
            echo "✅ All images verified!"
          }
        }
      }
      post {
        failure { echo "🚨 SIGNATURE VERIFICATION FAILED! Deployment BLOCKED!" }
      }
    }

  

    stage('Deploy to ECS') {
      steps {
        withCredentials([[
          $class: 'AmazonWebServicesCredentialsBinding',
          credentialsId: 'aws-ecr-credentials'
        ]]) {
          script {
            def services = [
              [image: 'frontend',     service: "${PROJECT}-${ENVIRONMENT}-frontend"],
              [image: 'gateway',      service: "${PROJECT}-${ENVIRONMENT}-gateway"],
              [image: 'user-service', service: "${PROJECT}-${ENVIRONMENT}-user-service"],
              [image: 'order-service',service: "${PROJECT}-${ENVIRONMENT}-order-service"]
            ]

            services.each { svc ->
              echo "Deploying: ${svc.service}"

              def taskDefArn = sh(
                script: "aws ecs describe-services --cluster ${CLUSTER_NAME} --services ${svc.service} --region ${AWS_REGION} --query 'services[0].taskDefinition' --output text",
                returnStdout: true
              ).trim()

              def newTaskDefArn = sh(
                script: """
                  TASK_DEF=\$(aws ecs describe-task-definition --task-definition ${taskDefArn} --region ${AWS_REGION} --query 'taskDefinition')
                  NEW_TASK_DEF=\$(echo \$TASK_DEF | python3 -c "
import json,sys
td=json.load(sys.stdin)
for c in td['containerDefinitions']:
    if c['name']=='${svc.image}':
        c['image']=c['image'].rsplit(':',1)[0]+':${env.DEPLOY_TAG}'
        print('Updated: '+c['image'],file=sys.stderr)
for f in ['taskDefinitionArn','revision','status','requiresAttributes','compatibilities','registeredAt','registeredBy']:
    td.pop(f,None)
print(json.dumps(td))
")
                  aws ecs register-task-definition --cli-input-json "\$NEW_TASK_DEF" --region ${AWS_REGION} --query 'taskDefinition.taskDefinitionArn' --output text
                """,
                returnStdout: true
              ).trim()

              echo "New task def: ${newTaskDefArn}"

              sh "aws ecs update-service --cluster ${CLUSTER_NAME} --service ${svc.service} --task-definition ${newTaskDefArn} --force-new-deployment --region ${AWS_REGION}"
              echo "✅ ${svc.service} update triggered!"
            }
          }
        }
      }
    }

    stage('Wait for Steady State') {
      steps {
        withCredentials([[
          $class: 'AmazonWebServicesCredentialsBinding',
          credentialsId: 'aws-ecr-credentials'
        ]]) {
          script {
            def services = [
              "${PROJECT}-${ENVIRONMENT}-frontend",
              "${PROJECT}-${ENVIRONMENT}-gateway",
              "${PROJECT}-${ENVIRONMENT}-user-service",
              "${PROJECT}-${ENVIRONMENT}-order-service"
            ]

            echo "Waiting for all services to stabilize..."
            services.each { serviceName ->
              sh "aws ecs wait services-stable --cluster ${CLUSTER_NAME} --services ${serviceName} --region ${AWS_REGION}"
              echo "✅ ${serviceName} stable!"
            }
            echo "✅ All services stable!"
          }
        }
      }
    }

    stage('Health Check') {
      steps {
        withCredentials([[
          $class: 'AmazonWebServicesCredentialsBinding',
          credentialsId: 'aws-ecr-credentials'
        ]]) {
          script {
            def albDns = sh(
              script: "aws elbv2 describe-load-balancers --region ${AWS_REGION} --names ${PROJECT}-${ENVIRONMENT}-alb --query 'LoadBalancers[0].DNSName' --output text",
              returnStdout: true
            ).trim()

            echo "ALB DNS: ${albDns}"
            env.APP_URL = "http://${albDns}"

            sleep(30)

            sh """
              echo "Checking frontend..."
              curl -f --retry 5 --retry-delay 10 http://${albDns}/ -o /dev/null -w "Frontend HTTP: %{http_code}\\n"
              echo "Checking dashboard API..."
              curl -f --retry 5 --retry-delay 10 http://${albDns}/api/dashboard -w "Dashboard HTTP: %{http_code}\\n"
              echo "✅ App is LIVE!"
              echo "🌐 URL: http://${albDns}"
            """
          }
        }
      }
    }
  }

  post {
    success {
      echo "✅ ECS DEPLOYMENT SUCCESSFUL! URL: ${env.APP_URL}"
      emailext(
        subject: "✅ ECS Deploy SUCCESS: ${env.DEPLOY_TAG}",
        body: "ECS Deployment Successful!\nTag: ${env.DEPLOY_TAG}\nURL: ${env.APP_URL}\nBuild: ${env.BUILD_URL}",
        to: "rajeshgovindan777@gmail.com"
      )
    }
    failure {
      echo "❌ ECS DEPLOYMENT FAILED!"
      emailext(
        subject: "❌ ECS Deploy FAILED: ${env.DEPLOY_TAG}",
        body: "ECS Deployment Failed!\nTag: ${env.DEPLOY_TAG}\nConsole: ${env.BUILD_URL}console",
        to: "rajeshgovindan777@gmail.com",
        attachLog: true
      )
    }
  }
}
