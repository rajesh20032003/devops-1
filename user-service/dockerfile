#multi build -> 149 mb
FROM node:22-alpine AS build
RUN apk update && apk upgrade --no-cache
WORKDIR /app
COPY package.json  package-lock.json .
RUN npm ci
COPY . .
FROM gcr.io/distroless/nodejs22-debian13
WORKDIR /app
COPY --from=build /app .
USER 65532
CMD ["server.js"]